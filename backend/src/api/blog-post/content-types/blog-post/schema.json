{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title_en": {
      "type": "string",
      "required": true
    },
    "title_ar": {
      "type": "string",
      "required": true
    },
    "body_en": {
      "type": "richtext"
    },
    "body_ar": {
      "type": "richtext"
    },
    "slug": {
      "type": "uid",
      "targetField": "title_en",
      "required": true
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "published_date": {
      "type": "date"
    },
    "category": {
      "type": "string"
    }
  }
}
